{
  "name": "retrospool-product-media",
  "private": true,
  "version": "0.0.0",
  "description": "Repeatable real-app screenshots of the RetroSpool admin console for GitHub Pages.",
  "type": "module",
  "scripts": {
    "build:frontend": "npm --prefix ../../frontend ci && npm --prefix ../../frontend run build",
    "capture": "npm run build:frontend && node capture-product-media.mjs",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "playwright": "1.61.1"
  }
}
